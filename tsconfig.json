{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": ".",              // ✅ Use project root instead of ./src
    "outDir": "./dist",
    "baseUrl": ".",              // ✅ Base URL at project root
    "paths": {
      "@/*": ["*"]               // ✅ Keep alias pointing to root files
    },
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["**/*.ts"],       // ✅ Include all TS files in root and subfolders
  "exclude": ["node_modules", "dist"]
}